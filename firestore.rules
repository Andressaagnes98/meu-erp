rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         (request.auth.token.email == "andressaabreu.g@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'sellingPrice', 'stockQuantity']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.sellingPrice is number && data.sellingPrice >= 0 &&
             data.stockQuantity is number && data.stockQuantity >= 0;
    }

    function isValidSale(data) {
      return data.keys().hasAll(['items', 'total', 'createdAt']) &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0;
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidProduct(request.resource.data);
      allow update: if isAuthenticated() && isValidProduct(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /sales/{saleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSale(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }
  }
}
